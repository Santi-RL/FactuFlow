{
  "name": "factuflow",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "lint": "node tools/run-backend-python.mjs -m ruff check app tests",
    "format": "node tools/run-backend-python.mjs -m black --check app tests",
    "test": "node tools/run-backend-python.mjs -m pytest tests -q",
    "clawpatch:backend:init": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend init",
    "clawpatch:backend:map:native": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend map",
    "clawpatch:backend:seed": "node tools/clawpatch/seed-features.mjs --area backend --root backend --state-dir .clawpatch/backend --strict",
    "clawpatch:backend:map": "npm run clawpatch:backend:map:native && npm run clawpatch:backend:seed",
    "clawpatch:backend:status": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend status --json",
    "clawpatch:backend:review": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend review --limit 50 --jobs 1",
    "clawpatch:backend:clean-locks": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend clean-locks",
    "clawpatch:frontend:init": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend init",
    "clawpatch:frontend:map:native": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend map",
    "clawpatch:frontend:seed": "node tools/clawpatch/seed-features.mjs --area frontend --root frontend --state-dir .clawpatch/frontend --strict",
    "clawpatch:frontend:map": "npm run clawpatch:frontend:map:native && npm run clawpatch:frontend:seed",
    "clawpatch:frontend:status": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend status --json",
    "clawpatch:frontend:review": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend review --limit 50 --jobs 1",
    "clawpatch:frontend:clean-locks": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend clean-locks",
    "clawpatch:repo:init": "node tools/clawpatch/run-clawpatch.mjs --root . --state-dir .clawpatch/repo init",
    "clawpatch:repo:seed": "node tools/clawpatch/seed-features.mjs --area repo --root . --state-dir .clawpatch/repo --strict",
    "clawpatch:repo:map": "npm run clawpatch:repo:seed",
    "clawpatch:repo:status": "node tools/clawpatch/run-clawpatch.mjs --root . --state-dir .clawpatch/repo status --json",
    "clawpatch:repo:review": "node tools/clawpatch/run-clawpatch.mjs --root . --state-dir .clawpatch/repo review --limit 50 --jobs 1",
    "clawpatch:repo:clean-locks": "node tools/clawpatch/run-clawpatch.mjs --root . --state-dir .clawpatch/repo clean-locks",
    "clawpatch:map-all": "npm run clawpatch:repo:map && npm run clawpatch:backend:map && npm run clawpatch:frontend:map",
    "clawpatch:test-seeds": "node --test tools/clawpatch/*.test.mjs"
  }
}
