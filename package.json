{
  "name": "factuflow",
  "version": "0.2.2",
  "private": true,
  "scripts": {
    "backend:lint": "node tools/run-backend-python.mjs -m ruff check app tests",
    "backend:format:check": "node tools/run-backend-python.mjs -m black --check app tests",
    "backend:test": "node tools/run-backend-python.mjs -m pytest tests -q",
    "frontend:lint": "npm --prefix frontend run lint:check",
    "frontend:type-check": "npm --prefix frontend run type-check",
    "frontend:test": "npm --prefix frontend run test:unit",
    "lint": "npm run backend:lint && npm run frontend:lint && npm run frontend:type-check",
    "test": "npm run backend:test && npm run frontend:test && npm run test:scripts",
    "test:scripts": "node --test tools/package-scripts.test.mjs",
    "clawpatch:backend:init": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend --config ../.clawpatch/backend/config.json init",
    "clawpatch:backend:map:native": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend --config ../.clawpatch/backend/config.json map",
    "clawpatch:backend:seed": "node tools/clawpatch/seed-features.mjs --area backend --root backend --state-dir .clawpatch/backend --strict",
    "clawpatch:backend:map": "npm run clawpatch:backend:map:native && npm run clawpatch:backend:seed",
    "clawpatch:backend:status": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend --config ../.clawpatch/backend/config.json status --json",
    "clawpatch:backend:review": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend --config ../.clawpatch/backend/config.json review --limit 50 --jobs 1",
    "clawpatch:backend:clean-locks": "node tools/clawpatch/run-clawpatch.mjs --root backend --state-dir ../.clawpatch/backend --config ../.clawpatch/backend/config.json clean-locks",
    "clawpatch:frontend:init": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend --config ../.clawpatch/frontend/config.json init",
    "clawpatch:frontend:map:native": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend --config ../.clawpatch/frontend/config.json map",
    "clawpatch:frontend:seed": "node tools/clawpatch/seed-features.mjs --area frontend --root frontend --state-dir .clawpatch/frontend --strict",
    "clawpatch:frontend:map": "npm run clawpatch:frontend:map:native && npm run clawpatch:frontend:seed",
    "clawpatch:frontend:status": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend --config ../.clawpatch/frontend/config.json status --json",
    "clawpatch:frontend:review": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend --config ../.clawpatch/frontend/config.json review --limit 50 --jobs 1",
    "clawpatch:frontend:clean-locks": "node tools/clawpatch/run-clawpatch.mjs --root frontend --state-dir ../.clawpatch/frontend --config ../.clawpatch/frontend/config.json clean-locks",
    "clawpatch:repo:init": "node tools/clawpatch/run-clawpatch.mjs --root . --state-dir .clawpatch/repo --config .clawpatch/repo/config.json init",
    "clawpatch:repo:map:native": "node tools/clawpatch/map-repo-native.mjs",
    "clawpatch:repo:seed": "node tools/clawpatch/seed-features.mjs --area repo --root . --state-dir .clawpatch/repo --strict",
    "clawpatch:repo:map": "npm run clawpatch:repo:map:native && npm run clawpatch:repo:seed",
    "clawpatch:repo:status": "node tools/clawpatch/run-clawpatch.mjs --root . --state-dir .clawpatch/repo --config .clawpatch/repo/config.json status --json",
    "clawpatch:repo:review": "node tools/clawpatch/run-clawpatch.mjs --root . --state-dir .clawpatch/repo --config .clawpatch/repo/config.json review --limit 50 --jobs 1",
    "clawpatch:repo:clean-locks": "node tools/clawpatch/run-clawpatch.mjs --root . --state-dir .clawpatch/repo --config .clawpatch/repo/config.json clean-locks",
    "clawpatch:map-all": "npm run clawpatch:repo:map && npm run clawpatch:backend:map && npm run clawpatch:frontend:map",
    "clawpatch:test-seeds": "node --test tools/clawpatch/*.test.mjs"
  }
}
