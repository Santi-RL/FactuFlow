# ====================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ====================================

# Entorno de la aplicación (development, production)
APP_ENV=development

# Clave secreta para JWT y encriptación
# IMPORTANTE: Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_SECRET_KEY=cambiar-esto-en-produccion-usar-secrets-token_urlsafe

# Activar modo debug (solo en desarrollo)
APP_DEBUG=true

# Host y puerto del backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ====================================
# BASE DE DATOS
# ====================================

# URL de conexión a la base de datos local con docker-compose.yml
DATABASE_URL=postgresql+asyncpg://factuflow:factuflow@postgres:5432/factuflow

# PostgreSQL local si ejecutas el backend fuera de Docker:
# DATABASE_URL=postgresql+asyncpg://factuflow:factuflow@localhost:5432/factuflow

# ====================================
# ARCA - CONFIGURACION
# ====================================

# Ambiente de ARCA: "homologacion" o "produccion"
# SIEMPRE empezar en homologacion para testing
ARCA_ENV=homologacion

# Ruta donde se almacenan los certificados
# IMPORTANTE: Esta carpeta debe tener permisos restrictivos
CERTS_PATH=./certs

# Compatibilidad legacy si todavia hay scripts usando AFIP_ENV / AFIP_CERTS_PATH
# AFIP_ENV=homologacion
# AFIP_CERTS_PATH=./certs

# Limites operativos para emision masiva
BATCH_SYNC_LIMIT=100
BATCH_MAX_ROWS=20000
BATCH_MAX_GROUPS=5000
BATCH_WORKER_ENABLED=true
BATCH_WORKER_POLL_SECONDS=5
BATCH_WORKER_BATCH_SIZE=1

# ====================================
# FRONTEND
# ====================================

# URL del backend (para llamadas API desde el frontend)
VITE_API_URL=http://localhost:8000

# URL base del frontend (para CORS en backend)
FRONTEND_URL=http://localhost:8080

# ====================================
# SMTP - ENVÍO DE EMAILS (Opcional)
# ====================================

# Configuración SMTP para enviar facturas por email
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-email@gmail.com
# SMTP_PASSWORD=tu-password-de-aplicacion
# SMTP_FROM_EMAIL=factuflow@tudominio.com
# SMTP_FROM_NAME=FactuFlow

# ====================================
# SEGURIDAD
# ====================================

# Lista de orígenes permitidos para CORS (separados por coma)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# Duración del JWT en minutos (default: 1440 = 24 horas)
JWT_EXPIRATION_MINUTES=1440

# ====================================
# LOGGING
# ====================================

# Nivel de logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Ruta del archivo de logs (opcional, si no se especifica usa stdout)
# LOG_FILE=./logs/factuflow.log

# ====================================
# CACHE (Opcional)
# ====================================

# Redis para cache de tokens ARCA (opcional)
# REDIS_URL=redis://localhost:6379/0

# ====================================
# OTROS
# ====================================

# Habilitar modo de mantenimiento
# MAINTENANCE_MODE=false

# Timezone
TZ=America/Argentina/Buenos_Aires
