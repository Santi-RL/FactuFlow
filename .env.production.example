# ====================================
# FACTUFLOW - PRODUCCION
# ====================================

APP_SECRET_KEY=generar-con-python-secrets-token_urlsafe-32
ARCA_PRIVATE_KEY_PASSWORD=generar-otra-clave-larga-para-cifrar-claves-arca

POSTGRES_DB=factuflow
POSTGRES_USER=factuflow
POSTGRES_PASSWORD=cambiar-por-password-fuerte

ARCA_ENV=produccion
CORS_ORIGINS=https://factuflow.tu-dominio.com
VITE_API_URL=https://factuflow.tu-dominio.com
FRONTEND_PORT=8080

FACTUFLOW_POSTGRES_DIR=./data/postgres
FACTUFLOW_DATA_DIR=./data/app
FACTUFLOW_CERTS_DIR=./certs
FACTUFLOW_LOGS_DIR=./logs

STORAGE_LIMIT_BYTES=10737418240
STORAGE_TMP_PATH=/app/data/tmp
STORAGE_LOG_RETENTION_DAYS=30
STORAGE_ENABLE_CLEANUP=true

BATCH_SYNC_LIMIT=100
BATCH_MAX_UPLOAD_BYTES=10485760
BATCH_MAX_ROWS=20000
BATCH_MAX_GROUPS=5000
BATCH_WORKER_ENABLED=true
BATCH_WORKER_POLL_SECONDS=5
BATCH_WORKER_BATCH_SIZE=1
BATCH_PROCESSING_STALE_MINUTES=120

LOG_LEVEL=INFO
TZ=America/Argentina/Buenos_Aires
